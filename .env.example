# Environment Variables Configuration
# Copy this file to .env and set actual values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Scraper Configuration
REQUEST_TIMEOUT=30
MAX_RETRIES=3
HEADLESS_BROWSER=true

# Proxy Configuration (comma-separated)
PROXY_LIST=
USE_PROXY_ROTATION=true

# Database Configuration
# For SQLite: sqlite:///./data/amazon.db
# For PostgreSQL: postgresql://user:password@localhost/amazon
DATABASE_URL=sqlite:///./data/amazon.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=

# AWS Credentials (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
